import subprocess
import os.path
import argparse
import shutil

# Search paths for MinGW DLLs - includes Fedora, Ubuntu, and MSYS2 paths
DEFAULT_PATH_PREFIXES = [
    "", "/usr/bin",
    # Fedora mingw64
    "/usr/x86_64-w64-mingw32/sys-root/mingw/bin",
    "/usr/x86_64-w64-mingw32/sys-root/mingw/lib",
    # Ubuntu mingw64
    "/usr/x86_64-w64-mingw32/lib",
    "/usr/lib/gcc/x86_64-w64-mingw32/10-posix",
    "/usr/lib/gcc/x86_64-w64-mingw32/10-win32",
    "/usr/lib/gcc/x86_64-w64-mingw32/12-posix",
    "/usr/lib/gcc/x86_64-w64-mingw32/12-win32",
    # MSYS2
    "/mingw64/bin",
    "C:\\msys64\\mingw64\\bin"
]

env_path_prefixes = os.environ.get('MINGW_BUNDLEDLLS_SEARCH_PATH', None)
if env_path_prefixes is not None:
    path_prefixes = [path for path in env_path_prefixes.split(os.pathsep) if path]
else:
    path_prefixes = DEFAULT_PATH_PREFIXES

# Windows system DLLs that should not be bundled
blacklist = [
    "advapi32.dll", "kernel32.dll", "msvcrt.dll", "ole32.dll", "user32.dll",
    "ws2_32.dll", "comdlg32.dll", "gdi32.dll", "imm32.dll", "oleaut32.dll",
    "shell32.dll", "winmm.dll", "winspool.drv", "wldap32.dll",
    "ntdll.dll", "d3d9.dll", "mpr.dll", "crypt32.dll", "dnsapi.dll",
    "shlwapi.dll", "version.dll", "iphlpapi.dll", "msimg32.dll", "setupapi.dll",
    "opengl32.dll", "dwmapi.dll", "uxtheme.dll", "secur32.dll", "gdiplus.dll",
    "usp10.dll", "comctl32.dll", "wsock32.dll", "netapi32.dll", "userenv.dll",
    "avicap32.dll", "avrt.dll", "psapi.dll", "mswsock.dll", "glu32.dll",
    "bcrypt.dll", "rpcrt4.dll", "hid.dll", "cfgmgr32.dll", "powrprof.dll",
    "xinput1_4.dll", "xinput9_1_0.dll", "dinput8.dll",
    # DirectX
    "d3d11.dll", "d3d12.dll", "dxgi.dll", "dwrite.dll", "d2d1.dll",
    # More Windows system DLLs
    "api-ms-win-crt-runtime-l1-1-0.dll",
    "api-ms-win-crt-heap-l1-1-0.dll",
    "api-ms-win-crt-string-l1-1-0.dll",
    "api-ms-win-crt-stdio-l1-1-0.dll",
    "api-ms-win-crt-convert-l1-1-0.dll",
    "api-ms-win-crt-math-l1-1-0.dll",
    "api-ms-win-crt-locale-l1-1-0.dll",
    "api-ms-win-crt-time-l1-1-0.dll",
    "api-ms-win-crt-filesystem-l1-1-0.dll",
    "api-ms-win-crt-environment-l1-1-0.dll",
    "api-ms-win-crt-process-l1-1-0.dll",
    "api-ms-win-crt-utility-l1-1-0.dll",
    "api-ms-win-core-path-l1-1-0.dll",
]


def find_full_path(filename, path_prefixes):
    for path_prefix in path_prefixes:
        path = os.path.join(path_prefix, filename)
        path_low = os.path.join(path_prefix, filename.lower())
        if os.path.exists(path):
            return path
        if os.path.exists(path_low):
            return path_low

    raise RuntimeError(
        "Can't find " + filename + ". If it is an inbuilt Windows DLL, "
        "please add it to the blacklist variable in the script."
    )


def gather_deps(path, path_prefixes, seen):
    ret = [path]
    try:
        output = subprocess.check_output(
            ["x86_64-w64-mingw32-objdump", "-p", path],
            stderr=subprocess.DEVNULL
        ).decode("utf-8", "replace").split("\n")
    except FileNotFoundError:
        # Fall back to regular objdump
        output = subprocess.check_output(
            ["objdump", "-p", path],
            stderr=subprocess.DEVNULL
        ).decode("utf-8", "replace").split("\n")

    for line in output:
        if not line.startswith("\tDLL Name: "):
            continue

        dep = line.split("DLL Name: ")[1].strip()
        ldep = dep.lower()

        if ldep in blacklist:
            continue

        if ldep in seen:
            continue

        try:
            dep_path = find_full_path(dep, path_prefixes)
        except RuntimeError as e:
            print(f"Warning: {e}")
            continue

        seen.add(ldep)
        subdeps = gather_deps(dep_path, path_prefixes, seen)
        ret.extend(subdeps)

    return ret


def main():
    parser = argparse.ArgumentParser(
        description="Bundle MinGW DLL dependencies for Windows executables"
    )
    parser.add_argument(
        "exe_file",
        help="EXE or DLL file that you need to bundle dependencies for"
    )
    parser.add_argument(
        "--copy",
        action="store_true",
        help="Copy dependencies next to the exe_file"
    )
    parser.add_argument(
        "--upx",
        action="store_true",
        help="Run UPX compression on copied files (requires --copy)"
    )
    args = parser.parse_args()

    if args.upx and not args.copy:
        raise RuntimeError("Can't run UPX if --copy hasn't been provided.")

    all_deps = set(gather_deps(args.exe_file, path_prefixes, set()))
    all_deps.remove(args.exe_file)

    print("\n".join(sorted(all_deps)))

    if args.copy:
        print("\nCopying dependencies...")
        parent_dir = os.path.dirname(os.path.abspath(args.exe_file))

        for dep in all_deps:
            target = os.path.join(parent_dir, os.path.basename(dep))

            try:
                print(f"  {os.path.basename(dep)}")
                shutil.copy(dep, parent_dir)
            except shutil.SameFileError:
                pass

            if args.upx:
                subprocess.call(["upx", "-q", target])


if __name__ == "__main__":
    main()
